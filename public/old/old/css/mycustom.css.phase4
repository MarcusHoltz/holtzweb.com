.btn {
  margin-top: 10px;
}
.txt-white,
.txt-white:hover {
  color: #fff;
}

.tomato {
  background: tomato;
  text-shadow: 0 -1px 1px rgb(75, 20, 11);
  border-bottom: 4px solid rgb(201, 71, 50);
}

.tomato:hover {
  background: rgb(201, 71, 50);
  text-shadow: 0 -1px 1px rgb(75, 20, 11);
  border-bottom: 4px solid rgb(153, 51, 51);
}

.tomato:active {
  border-bottom: 0px;
}

.green {
  background: #a0cc80;
  text-shadow: 0 -1px 1px rgb(38, 131, 21);
  border-bottom: 4px solid rgb(120, 180, 139);
}

.green:hover {
  background: rgb(120, 180, 139);
  text-shadow: 0 -1px 1px rgb(38, 131, 21);
  border-bottom: 4px solid #789770;
}

.yellow {
  background: #f7c475;
  text-shadow: 0 -1px 1px rgb(184, 130, 15);
  border-bottom: 4px solid rgb(209, 165, 86);
}

.yellow:hover {
  background: rgb(209, 165, 86);
  text-shadow: 0 -1px 1px rgb(184, 130, 15);
  border-bottom: 4px solid #d19058;
}



.midnight-purple {
  background: #625192;
  text-shadow: 0 -1px 1px #887BAF;
  border-bottom: 4px solid #413075;
}

.midnight-purple:hover {
  background: #413075;
  text-shadow: 0 -1px 1px #625192;
  border-bottom: 4px solid #14073A;
}



.blue {
  background: #4d9ae5;
  text-shadow: 0 -1px 1px rgb(12, 67, 126);
  border-bottom: 4px solid rgb(62, 133, 199);
}

.blue:hover {
  background: rgb(62, 133, 199);
  text-shadow: 0 -1px 1px rgb(12, 67, 126);
  border-bottom: 4px solid #3366cc;
}




.btn-flat {
  background: #84ccd3 repeat scroll 0 0;
  font-family: "Lato", sans-serif;
  border-bottom: 5px solid #69acaf;
  border-radius: 2px;
  box-shadow: none;
  text-decoration: none;
  text-shadow: none;
  padding-top: 6px;
}

.btn-flat:hover {
  background: #76bdc3;
  color: #ffffff;
  text-decoration: none;
  transition: all 0.35s ease 0s;
}

.regal {
  background-color: none;
  background-image: none;
  cursor: pointer;
  text-shadow: 0 -1px 0 #030304;
  -webkit-border-radius: 2px;
  -moz-border-radius: 2px;
  border-radius: 2px;
  -webkit-background-clip: padding-box;
  -moz-background-clip: padding;
  background-clip: padding-box;
  -webkit-box-shadow: inset 0 0 0 rgba(0, 0, 0, 0);
  -moz-box-shadow: inset 0 0 0 rgba(0, 0, 0, 0);
  box-shadow: inset 0 0 0 rgba(0, 0, 0, 0);
}

.regal-red {
  background: #fb3c2d;
  text-shadow: 0 -1px 0 #be1104;
  border: 1px solid #fb3c2d;
}

.regal-green {
  background: #008000;
  text-shadow: 0 -1px 0 #001a00;
  border: 1px solid #008000;
}

.regal-blue {
  background: #369;
  text-shadow: 0 -1px 0 #19334d;
  border: 1px solid #369;
}

.regal-maroon {
  background: #bb2525;
  text-shadow: 0 -1px 0 #661414;
  border: 1px solid #bb2525;
}

.regal-orange {
  background: #f60;
  text-shadow: 0 -1px 0 #993d00;
  border: 1px solid #f60;
}
.regal-inverse {
  background: #1a1a1a;
  text-shadow: 0 -1px 0 #000;
  border: 1px solid #1a1a1a;
}







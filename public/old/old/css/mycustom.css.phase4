body {
  background: #161A1E;
  background-color: #161A1E;
  font-family: 'Claxton', sans-serif;
    overflow: hidden;
}

body {
  background-image: url(../lol/xbmc4.jpg);
  background-size: cover;
  background-position-y: 130px;
  background-repeat: repeat;
/*  height: 100%;  */
  height: 100vh;
/*  height: calc(100% - 27px);  */
}


.slider {
    width: 20vw;
	height: 20vw;
    -webkit-background-size:100% 100%;
    -moz-background-size:100% 100%;
    background-repeat:no-repeat;
	background-size: 100% auto;
}

 @font-face {
    font-family: 'Claxton';
    src: url(data:application/font-woff2;charset=utf-8;base64,) format('woff2'), url(data:application/font-woff;charset=utf-8;base64,) format('woff');
    font-weight: normal;
    font-style: normal;
  }


/**********************************
Responsive navbar-brand image CSS
- Remove navbar-brand padding for firefox bug workaround
- add 100% height and width auto ... similar to how bootstrap img-responsive class works
***********************************/

.navbar { margin-bottom: 0px; } 

.navbar-brand {
  padding: 0px;
}
.navbar-brand>img {
  height: 100%;
  padding: 15px;
  width: auto;
}


/* CSS Transform Align Navbar Brand Text ... This could also be achieved with table / table-cells */
.navbar-alignit .navbar-header {
	  -webkit-transform-style: preserve-3d;
  -moz-transform-style: preserve-3d;
  transform-style: preserve-3d;
  height: 50px;
}
.navbar-alignit .navbar-brand {
	top: 50%;
	display: block;
	position: relative;
	height: auto;
	transform: translate(0,-50%);
	margin-right: 15px;
  margin-left: 15px;
}



.close {
  position: relative;
  font-size: 5rem;
  bottom: 5rem;
  color: hsl(236, 50%, 50%);
}


.glitch {
  color: white;
  font-size: 100px;
  position: relative;
  width: 400px;
  margin: 0 auto;
}

@keyframes noise-anim {
  0% {
    clip: rect(40px, 9999px, 98px, 0);
  }
  5% {
    clip: rect(13px, 9999px, 6px, 0);
  }
  10% {
    clip: rect(63px, 9999px, 95px, 0);
  }
  15% {
    clip: rect(35px, 9999px, 97px, 0);
  }
  20% {
    clip: rect(50px, 9999px, 35px, 0);
  }
  25% {
    clip: rect(93px, 9999px, 3px, 0);
  }
  30% {
    clip: rect(1px, 9999px, 27px, 0);
  }
  35% {
    clip: rect(71px, 9999px, 87px, 0);
  }
  40% {
    clip: rect(92px, 9999px, 31px, 0);
  }
  45% {
    clip: rect(1px, 9999px, 48px, 0);
  }
  50% {
    clip: rect(55px, 9999px, 61px, 0);
  }
  55% {
    clip: rect(62px, 9999px, 74px, 0);
  }
  60% {
    clip: rect(84px, 9999px, 4px, 0);
  }
  65% {
    clip: rect(20px, 9999px, 56px, 0);
  }
  70% {
    clip: rect(26px, 9999px, 42px, 0);
  }
  75% {
    clip: rect(57px, 9999px, 75px, 0);
  }
  80% {
    clip: rect(12px, 9999px, 17px, 0);
  }
  85% {
    clip: rect(60px, 9999px, 32px, 0);
  }
  90% {
    clip: rect(69px, 9999px, 35px, 0);
  }
  95% {
    clip: rect(69px, 9999px, 34px, 0);
  }
  100% {
    clip: rect(91px, 9999px, 99px, 0);
  }
}
.glitch:after {
  content: attr(data-text);
  position: absolute;
  left: 2px;
  text-shadow: -1px 0 red;
  top: 0;
  color: white;
  background: black;
  overflow: hidden;
  clip: rect(0, 900px, 0, 0);
  animation: noise-anim 2s infinite linear alternate-reverse;
}

@keyframes noise-anim-2 {
  0% {
    clip: rect(54px, 9999px, 11px, 0);
  }
  5% {
    clip: rect(52px, 9999px, 93px, 0);
  }
  10% {
    clip: rect(64px, 9999px, 29px, 0);
  }
  15% {
    clip: rect(58px, 9999px, 71px, 0);
  }
  20% {
    clip: rect(54px, 9999px, 38px, 0);
  }
  25% {
    clip: rect(22px, 9999px, 4px, 0);
  }
  30% {
    clip: rect(29px, 9999px, 77px, 0);
  }
  35% {
    clip: rect(1px, 9999px, 98px, 0);
  }
  40% {
    clip: rect(75px, 9999px, 3px, 0);
  }
  45% {
    clip: rect(27px, 9999px, 89px, 0);
  }
  50% {
    clip: rect(1px, 9999px, 4px, 0);
  }
  55% {
    clip: rect(77px, 9999px, 67px, 0);
  }
  60% {
    clip: rect(65px, 9999px, 22px, 0);
  }
  65% {
    clip: rect(75px, 9999px, 89px, 0);
  }
  70% {
    clip: rect(56px, 9999px, 62px, 0);
  }
  75% {
    clip: rect(43px, 9999px, 69px, 0);
  }
  80% {
    clip: rect(26px, 9999px, 70px, 0);
  }
  85% {
    clip: rect(94px, 9999px, 7px, 0);
  }
  90% {
    clip: rect(66px, 9999px, 35px, 0);
  }
  95% {
    clip: rect(86px, 9999px, 87px, 0);
  }
  100% {
    clip: rect(46px, 9999px, 90px, 0);
  }
}
.glitch:before {
  content: attr(data-text);
  position: absolute;
  left: -2px;
  text-shadow: 1px 0 blue;
  top: 0;
  color: white;
  background: black;
  overflow: hidden;
  clip: rect(0, 900px, 0, 0);
  animation: noise-anim-2 3s infinite linear alternate-reverse;
}
.square { border-color: white; border-style: solid; border-width: 5px; 
background: black;
background-size: 125% auto;
background-position: top left;
filter: grayscale(50%) brightness(93%);
margin: 0px auto;
padding: 2.5em 2em .5em 0;
}

.glitch { 
text-align: left;
margin: 0 -21px;
font-size: 4em;
width: calc(1.25*3em);
letter-spacing: 2.5px;
} 

.glitch span, span.glitch { display: none; } 
.glitch, .glitch a, .glitch span, .glitch:before, .glitch:after,  .square .glitch,
a.glitch, a.glitch a, a.glitch span, a.glitch:before, a.glitch:after,  .square a.glitch,
a .glitch, a .glitch a, a .glitch span, a .glitch:before, a .glitch:after,  .square a .glitch, 
.navbar-header, .navbar-header a, .navbar-header a .glitch { text-decoration: none !important } 




        font-size: 4em; font-weight: bold; color:#ca77f3; text-shadow: -1px -1px 0 #000,  1px -1px 0 #000, -1px 1px 0 #000, 1px 1px 0 #000;     }
.modal-body { text-align: center; } 


.welcome .wtop { font-family: 'Claxton', sans-serif; font-size: 2.5rem; font-weight: 700; letter-spacing: .75px; padding: 5px 0px; margin-bottom: 15px; text-shadow: 1px 2px 2px #eee; border-top: 5px solid #F0F8FF; border-bottom: 5px solid #F0F8FF; } 
.welcome .wagon {  height: 2px; position: relative; width: 108%; left: -4%; background-color: transparent; } 








.welcome h5 { border: 3px solid #101010; font-family: 'Claxton', sans-serif; font-weight: 700; line-height: 1.1; display: inline-block; padding: 2px 50px; 
			font-size: 5rem; box-shadow: 2px 2px 2px inset #d2d2d2;  text-shadow: 1px 1px 0px #d2d2d2;

} 
.welcome .cust-info { position: relative;  font-size: 1em; margin: 0 auto -15px; } 


.center-button .btn { margin: 25px 25px 15px; font-size: 16px; padding: 6px 26px; } 

.welcome .cust-info span {     margin: -.1em -0.15em;  } 
.welcome .cust-info span:first-of-type {  } 



.welcome .cust-info {
  color: #07080a;
  font-family: Helvetica Neue, Helvetica, Tahoma, sans-serif;
  font-size: 1em;
  font-weight: 700;
  border-bottom: 2px solid #0a0a0a;
  margin: -5px 24% 0px;
}
.welcome .cust-info span {
  display: inline-block;
  position: relative;
  -webkit-transform-style: preserve-3d;
          transform-style: preserve-3d;
  -webkit-perspective: 500;
          perspective: 500;
  -webkit-font-smoothing: antialiased;
}
.welcome .cust-info span::before,
.welcome .cust-info span::after {
  display: none;
  position: absolute;
  top: 0;
  left: -1px;
  -webkit-transform-origin: left top;
          transform-origin: left top;
  transition: all ease-out 0.3s;
  content: attr(data-text);
}
.welcome .cust-info span::before {
  z-index: 1;
  color: rgba(0,0,0,0.2);
  -webkit-transform: scale(1.1, 1) skew(0deg, 5deg);
          transform: scale(1.1, 1) skew(0deg, 5deg);
}
.welcome .cust-info span::after {
  z-index: 2;
  color: #684da3;
  text-shadow: -1px 0 1px #684da3, 1px 0 1px rgba(0,0,0,0.8);
  -webkit-transform: rotateY(-10deg);
          transform: rotateY(-10deg);
}
.welcome .cust-info span:hover::before {
  -webkit-transform: scale(1.1, 1) skew(0deg, 20deg);
          transform: scale(1.1, 1) skew(0deg, 20deg);
}
.welcome .cust-info span:hover::after {
  -webkit-transform: rotateY(-40deg);
          transform: rotateY(-40deg);
}
.welcome .cust-info span + span {
  margin-left: 2px;
}

.welcome .cust-info { font-size: 6rem; }


@media (min-width: 20em) {
  .welcome .cust-info {
    font-size: 1em;
  }
  .welcome .cust-info span::before,
  .welcome .cust-info span::after {
    display: block;
  }
}
@media (min-width: 30em) {
  .welcome .cust-info {
    font-size: 2rem;
  }
}
@media (min-width: 40em) {
  .welcome .cust-info {
    font-size: 3rem;
  }
}
@media (min-width: 60em) {
  .welcome .cust-info {
    font-size: 6rem;
  }
}

.portfolio-pictures span { font-size: 4em; 
    bottom: 7px;
    position: relative;
    letter-spacing: 0.15em;
    text-shadow: 2px 2px 1px #969C96; text-decoration: underline;
}


.portfolio-pictures p { margin-bottom: 70px; }
.portfolio-pictures p:last-of-type { margin-bottom: 0px; }


---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import siteData from "@/data/global/site.json";
import servicesData from "@/data/services/services.json";
import { withBase } from "@/lib/assetPath";

const service = servicesData.find((s) => s.slug === "linux-server-administration")!;
---

<Layout
  title={service.pageMeta.title}
  description={`${service.pageMeta.description} by ${siteData.name}.`}
>
  <div class="px-6 lg:px-12 py-16">
    <div class="max-w-5xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-site-muted font-mono">
          <li><a href={withBase('/')} data-astro-reload class="hover:text-white transition-colors">Home</a></li>
          <li class="text-site-border">/</li>
          <li><a href={withBase('/services')} class="hover:text-white transition-colors">Services</a></li>
          <li class="text-site-border">/</li>
          <li class={service.theme.accent}>Linux Server Admin</li>
        </ol>
      </nav>

      <div class="mb-12">
        <div class={`inline-flex items-center gap-2 px-3 py-1.5 rounded-full border ${service.theme.badgeBorder} ${service.theme.badgeBg} mb-5`}>
          <span class={`text-xs font-mono font-medium ${service.theme.accent} uppercase tracking-wider`}>{service.intro.badge}</span>
        </div>
        <h1 class="font-display font-bold text-4xl sm:text-5xl text-white mb-4">{service.intro.heading}</h1>
        <p class="text-site-text-muted text-xl leading-relaxed max-w-3xl">
          {service.intro.subHeading}
        </p>
      </div>

      <!-- Deployment Terminal -->
      <div class="mb-12 rounded-2xl border border-site-border bg-navy-800/80 overflow-hidden">

        <!-- Window chrome -->
        <div class="flex items-center justify-between px-4 py-3 bg-navy-950/60 border-b border-site-border">
          <div class="flex items-center gap-1.5">
            <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">─</span>
            <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">□</span>
            <span class="inline-flex items-center justify-center w-4 h-3 text-[9px] leading-none text-site-muted/50 border border-site-muted/20 rounded-[2px] font-mono select-none">×</span>
          </div>
          <div class="text-[10px] font-mono uppercase tracking-[0.25em] text-site-muted hidden sm:block">
            Global Infrastructure Orchestration
          </div>
          <div class="flex items-center gap-2 font-mono text-xs text-emerald-400">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse"></span>
            LIVE
          </div>
        </div>

        <!-- Body: sidebar + log pane -->
        <div class="grid lg:grid-cols-[270px_1fr]">

          <!-- SIDEBAR -->
          <div class="hidden lg:block border-b lg:border-b-0 lg:border-r border-site-border bg-navy-950/40 p-5 space-y-5">

            <div>
              <div class="mb-3 text-[10px] font-semibold uppercase tracking-[0.2em] text-site-muted">Infrastructure Health</div>
              <div class="space-y-3">

                <!-- K8s -->
                <div class="rounded-xl border border-site-border bg-site-surface/20 p-3.5">
                  <div class="flex items-center justify-between">
                    <div>
                      <div class="text-sm font-medium text-site-text">Kubernetes</div>
                      <div class="text-xs text-site-muted mt-0.5">6 Active Clusters</div>
                    </div>
                    <div class="flex items-center gap-1.5 text-xs text-emerald-400">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse"></span>
                      Healthy
                    </div>
                  </div>
                  <div class="mt-3 h-1 overflow-hidden rounded-full bg-site-border/40">
                    <div class="h-full w-[86%] rounded-full bg-emerald-400"></div>
                  </div>
                </div>

                <!-- CI/CD -->
                <div class="rounded-xl border border-site-border bg-site-surface/20 p-3.5">
                  <div class="flex items-center justify-between">
                    <div>
                      <div class="text-sm font-medium text-site-text">CI/CD Pipeline</div>
                      <div class="text-xs text-site-muted mt-0.5">GitLab Workflow + Ansible</div>
                    </div>
                    <div class="flex items-center gap-1.5 text-xs text-emerald-400">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse"></span>
                      Deploying
                    </div>
                  </div>
                  <div class="mt-3 h-1 overflow-hidden rounded-full bg-site-border/40">
                    <div class="h-full w-[68%] rounded-full bg-emerald-400"></div>
                  </div>
                </div>

                <!-- Edge Network -->
                <div class="rounded-xl border border-site-border bg-site-surface/20 p-3.5">
                  <div class="flex items-center justify-between">
                    <div>
                      <div class="text-sm font-medium text-site-text">Edge Network</div>
                      <div class="text-xs text-site-muted mt-0.5">Cloudflare + 3 Regions</div>
                    </div>
                    <div class="flex items-center gap-1.5 text-xs text-emerald-400">
                      <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse"></span>
                      Online
                    </div>
                  </div>
                  <div class="mt-3 flex gap-1.5">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse" style="animation-delay:0ms"></span>
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse" style="animation-delay:100ms"></span>
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse" style="animation-delay:200ms"></span>
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse" style="animation-delay:320ms"></span>
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse" style="animation-delay:450ms"></span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Uptime Monitor -->
            <div>
              <div class="mb-3 text-[10px] font-semibold uppercase tracking-[0.2em] text-site-muted">Service Uptime</div>
              <div class="rounded-xl border border-site-border bg-site-surface/20 p-3.5">
                <div class="flex items-center justify-between mb-3">
                  <div class="flex items-center gap-1.5">
                    <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 deploy-pulse flex-shrink-0"></span>
                    <span class="text-xs font-medium text-site-text">API Gateway</span>
                  </div>
                  <span class="uptime-pct-badge" id="uptimePct"></span>
                </div>
                <div class="uptime-ticks" id="uptimeTicks" role="img" aria-label="Uptime history"></div>
                <div class="uptime-time-labels" id="uptimeTimeLabels"></div>
              </div>
            </div>

          </div>

          <!-- LOG PANE -->
          <div class="p-4 sm:p-5 bg-navy-950/30">
            <div class="rounded-xl border border-site-border bg-black/30 p-4">

              <!-- inner terminal header -->
              <div class="mb-3 flex items-center justify-between">
                <div class="font-mono text-xs text-site-muted">tail -f /var/log/production-deploy.log</div>
                <div class="flex items-center gap-1.5 font-mono text-xs text-emerald-400">
                  <span class="h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                  STREAMING
                </div>
              </div>

              <!-- scrolling log window -->
              <div class="log-mask relative h-[360px] overflow-hidden">

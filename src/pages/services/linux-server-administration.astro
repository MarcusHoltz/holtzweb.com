<style is:global>
  @keyframes deployPulse {
    0%, 100% { opacity: 0.4; }
    50%       { opacity: 1; }
  }

  @keyframes dashFlow {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: -24; }
  }

  .log-scroll {
    transition: transform 160ms ease-out;
  }

  .deploy-pulse {
    animation: deployPulse 2.5s ease-in-out infinite;
  }

  .dash-anim {
    animation: dashFlow 2s linear infinite;
  }

  .log-mask::before,
  .log-mask::after {
    content: "";
    position: absolute;
    left: 0;
    width: 100%;
    height: 56px;
    z-index: 10;
    pointer-events: none;
  }

  .log-mask::before {
    top: 0;
    background: linear-gradient(to bottom, var(--bg-elevated), transparent);
  }

  .log-mask::after {
    bottom: 0;
    background: linear-gradient(to top, var(--bg-base), transparent);
  }

  .uptime-pct-badge {
    font-family: monospace;
    font-size: 10px;
    font-weight: 600;
    color: #34d399;
    background: rgba(52,211,153,0.1);
    border: 1px solid rgba(52,211,153,0.2);
    padding: 2px 7px;
    border-radius: 4px;
  }

  .uptime-ticks {
    display: flex;
    gap: 2px;
    height: 22px;
    align-items: stretch;
    margin-bottom: 5px;
  }

  .uptime-tick {
    flex: 1;
    min-width: 0;
    border-radius: 2px;
    cursor: pointer;
    transition: transform 0.12s ease, filter 0.12s ease, opacity 0.12s ease;
  }
  .uptime-tick.status-up { background: #34d399; opacity: 0.65; }
  .uptime-tick:hover {
    transform: scaleY(1.4);
    opacity: 1 !important;
    filter: brightness(1.3);
    z-index: 10;
    position: relative;
  }

  .uptime-time-labels {
    display: flex;
    justify-content: space-between;
    font-family: monospace;
    font-size: 9px;
    color: rgba(148,163,184,0.4);
  }

  .uptime-tooltip {
    position: fixed;
    pointer-events: none;
    background: #0f172a;
    border: 1px solid rgba(52,211,153,0.25);
    border-radius: 8px;
    padding: 8px 11px;
    z-index: 9999;
    opacity: 0;
    transition: opacity 0.12s ease;
    box-shadow: 0 8px 24px rgba(0,0,0,0.6);
    white-space: nowrap;
  }
  .uptime-tooltip.visible { opacity: 1; }
  .uptime-tooltip .utt-time {
    font-family: monospace;
    font-size: 10px;
    color: rgba(226,232,240,0.6);
    margin-bottom: 3px;
  }
  .uptime-tooltip .utt-status {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    font-family: monospace;
  }
  .uptime-tooltip .utt-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; }
  .uptime-tooltip .utt-status.up       { color: #34d399; }
  .uptime-tooltip .utt-status.up       .utt-dot { background: #34d399; }
  .uptime-tooltip .utt-status.down     { color: #f87171; }
  .uptime-tooltip .utt-status.down     .utt-dot { background: #f87171; }
  .uptime-tooltip .utt-status.degraded { color: #fbbf24; }
  .uptime-tooltip .utt-status.degraded .utt-dot { background: #fbbf24; }
</style>

<script>
  (function () {
    const rawEl = document.querySelector('.log-scroll');
    if (!rawEl) return;
    const el = rawEl as HTMLElement;

    // line-height: 11px font * 1.7 leading = 18.7px
    const LINE_H = 11 * 1.7;
    let y = 0;
    let half = 0;

    function measure() {
      // content is duplicated, so half the scroll height is one full cycle
      half = el.scrollHeight / 2;
    }

    function step() {
      const lines = Math.floor(Math.random() * 3) + 1; // 1, 2, or 3
      y += lines * LINE_H;
      if (y >= half) y -= half;
      el.style.transform = `translateY(-${y}px)`;

      // 350ms–1600ms random pause between bumps
      const delay = 350 + Math.random() * 1250;
      setTimeout(step, delay);
    }

    // Let the page render fully before measuring
    requestAnimationFrame(() => requestAnimationFrame(() => {
      measure();
      setTimeout(step, 800);
    }));
  })();
</script>

<script>
  (function () {
    const TICK_COUNT = 45;
    const MINS = 2;

    const now = new Date();
    const data: { time: Date; status: 'up' }[] = Array.from({ length: TICK_COUNT }, (_, i) => ({
      time: new Date(now.getTime() - (TICK_COUNT - 1 - i) * MINS * 60000),
      status: 'up' as const,
    }));

    const ticksEl = document.getElementById('uptimeTicks');
    const pctEl   = document.getElementById('uptimePct');
    const labsEl  = document.getElementById('uptimeTimeLabels');
    if (!ticksEl || !pctEl || !labsEl) return;

    data.forEach((_d, i) => {
      const el = document.createElement('div');
      el.className = 'uptime-tick status-up';
      el.dataset.index = String(i);
      ticksEl.appendChild(el);
    });

    pctEl.textContent = '100.0% up';

    const fmt = (d: Date) => d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false });
    labsEl.innerHTML = `<span>${fmt(data[0].time)}</span><span>${fmt(data[data.length - 1].time)}</span>`;

    const tooltip = document.createElement('div');
    tooltip.className = 'uptime-tooltip';
    tooltip.innerHTML = '<div class="utt-time"></div><div class="utt-status"></div>';
    document.body.appendChild(tooltip);

    ticksEl.addEventListener('mouseover', (e) => {
      const target = e.target as Element | null;
      const tick = target?.closest('.uptime-tick') as HTMLElement | null;
      if (!tick) return;
      const d = data[parseInt(tick.dataset.index ?? '0')];
      const r = tick.getBoundingClientRect();
      const timeEl = tooltip.querySelector('.utt-time');
      const statusEl = tooltip.querySelector('.utt-status');
      if (timeEl) timeEl.textContent = fmt(d.time);
      if (statusEl) {
        statusEl.className = 'utt-status up';
        statusEl.innerHTML = '<span class="utt-dot"></span>Operational';
      }
      tooltip.style.left      = `${r.left + r.width / 2}px`;
      tooltip.style.top       = `${r.top - 8}px`;
      tooltip.style.transform = 'translate(-50%, -100%)';
      tooltip.classList.add('visible');
    });

    ticksEl.addEventListener('mouseout', (e) => {
      const target = e.target as Element | null;
      if (target?.closest('.uptime-tick')) tooltip.classList.remove('visible');
    });
  })();
</script>

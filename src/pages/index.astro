---
import Layout from "@/layouts/Layout.astro";
import siteData from "@/data/global/site.json";
import Hero from "@/components/Hero.astro";
import ITlandscape from "@/components/ITlandscape.astro";
import FeaturedSlider from "@/components/FeaturedSlider.astro";
import Marcus from "@/components/Marcus.astro";
import Services from "@/components/Services.astro";
import Holtzhost from "@/components/Holtzhost.astro";
import Projects from "@/components/Projects.astro";
import QuickHelpForm from "@/components/QuickHelpForm.astro";
import Footer from "@/components/Footer.astro";
---

<Layout
  title={siteData.name}
  description={siteData.description}
>
  <Hero />
  <ITlandscape />
  <FeaturedSlider />
  <Marcus />
  <Services />
  <Holtzhost />
  <Projects featuredOnly />
  <QuickHelpForm />
  <Footer />
</Layout>
